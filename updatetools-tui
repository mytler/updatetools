#!/usr/bin/env bash
# updatetools-tui ‚Äî animated full-screen dashboard front-end for updatetools.
#
# Runs the real update steps one by one and renders a live dashboard:
# spinner, per-step status, progress bar, elapsed timer, and a tail of the
# current command's output. Verbose output is streamed to a log file so the
# dashboard stays clean. When done it shows a summary IN the dashboard and waits
# for you to press 'q' to quit.
#
# Usage:
#   updatetools-tui            # update all software (no OS reboot)
#   updatetools-tui --macos    # ALSO install macOS + App Store updates
#   updatetools-tui --no-greedy
#   (press q to leave the summary screen)
set -u

# ---------------------------------------------------------------------------
# Config / args
# ---------------------------------------------------------------------------
MACOS_UPDATES="${MACOS_UPDATES:-0}"
GREEDY="${GREEDY:-1}"
# Watchdog: kill a step that emits no output for this many seconds (it's almost
# certainly wedged). 0 disables. PROMPT_TIMEOUT bounds how long a sudo/ssh prompt
# waits for input before the step is aborted, so an unattended run never freezes.
STALL_TIMEOUT="${STALL_TIMEOUT:-300}"
PROMPT_TIMEOUT="${PROMPT_TIMEOUT:-300}"
for arg in "$@"; do
  case "$arg" in
    --macos|--all) MACOS_UPDATES=1 ;;
    --no-greedy)   GREEDY=0 ;;
    --plain|--no-pretty|--no-tui)
      # Caller explicitly wants plain output ‚Äî hand off to updatetools --plain.
      plain="$(dirname "$0")/updatetools"
      rest=(); for a in "$@"; do case "$a" in --plain|--no-pretty|--no-tui) ;; *) rest+=("$a") ;; esac; done
      exec "$plain" --plain ${rest[@]+"${rest[@]}"} ;;
    -h|--help)     sed -n '2,14p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) echo "Unknown option: $arg"; exit 2 ;;
  esac
done
[ "$GREEDY" = "1" ] && GREEDY_FLAG="--greedy" || GREEDY_FLAG=""

# ---------------------------------------------------------------------------
# Homebrew env
# ---------------------------------------------------------------------------
if [ -x /opt/homebrew/bin/brew ]; then eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then eval "$(/usr/local/bin/brew shellenv)"; fi

have() { command -v "$1" >/dev/null 2>&1; }

# Recursively terminate a process and all of its descendants. A background step
# spawns children (brew ‚Üí sudo ‚Üí launchctl, ‚Ä¶); killing only the top pid would
# orphan a wedged child, so walk the tree via pgrep first.
kill_tree() {
  local p="$1" c
  for c in $(pgrep -P "$p" 2>/dev/null); do kill_tree "$c"; done
  kill -TERM "$p" 2>/dev/null
}

# Ensure a UTF-8 locale so ${#str} counts characters (not bytes) ‚Äî keeps the
# box border aligned regardless of how the shell was invoked.
if ! printf '%s' "${LC_ALL:-${LANG:-}}" | grep -qi 'utf-8'; then
  if locale -a 2>/dev/null | grep -qi '^en_US.UTF-8$'; then
    export LC_ALL=en_US.UTF-8
  fi
fi

# Portable symlink resolver (BSD readlink lacks a reliable -f).
resolve_link() {
  local p="$1" t dir
  while [ -L "$p" ]; do
    t="$(readlink "$p")"
    case "$t" in
      /*) p="$t" ;;
      *)  dir="$(cd "$(dirname "$p")" && pwd)"; p="$(cd "$dir" && cd "$(dirname "$t")" && pwd)/$(basename "$t")" ;;
    esac
  done
  printf '%s' "$p"
}

# Codex CLI may be an npm package in a NON-default prefix (e.g. iCloud .local),
# and/or the codex-app desktop cask. Update whatever is actually present.
update_codex() {
  local real prefix updated=0
  real="$(resolve_link "$(command -v codex)" 2>/dev/null)"
  case "$real" in
    */lib/node_modules/@openai/codex/*)
      prefix="${real%%/lib/node_modules/*}"
      echo "Updating codex CLI in prefix: $prefix"
      npm install -g @openai/codex@latest --prefix "$prefix" && updated=1 ;;
    *)
      if have npm && npm list -g @openai/codex >/dev/null 2>&1; then
        npm install -g @openai/codex@latest && updated=1
      fi ;;
  esac
  if have brew && brew list --cask codex-app >/dev/null 2>&1; then
    echo "Updating codex-app cask"
    brew upgrade --cask codex-app $GREEDY_FLAG; updated=1
  fi
  [ "$updated" = 1 ] || { echo "codex present but no known update source matched"; return 1; }
}

npm_update_global() {
  # npm itself lives in /opt/homebrew and is brew-managed; npm update -g includes it
  # and fails with EACCES. Update only non-npm packages explicitly.
  local pkgs
  pkgs=$(npm outdated -g --depth=0 --parseable 2>/dev/null \
    | cut -d: -f4 | sed 's/@[^@]*$//' | grep -v '^npm$' | tr '\n' ' ')
  [ -n "$pkgs" ] && npm install -g $pkgs || true
  # Cache may have root-owned files from an old npm bug; verify non-fatally.
  npm cache verify || true
}

pnpm_update_global() {
  pnpm self-update 2>/dev/null || brew upgrade pnpm 2>/dev/null || true
  # pnpm's global bin dir may not be in PATH when launched non-interactively.
  local pnpm_bin
  pnpm_bin="$(pnpm config get global-bin-dir 2>/dev/null)"
  [ -n "$pnpm_bin" ] && export PATH="$PATH:$pnpm_bin"
  pnpm update -g --latest || true
}

LOG="${TMPDIR:-/tmp}/updatetools-$$.log"
: > "$LOG"

# ---------------------------------------------------------------------------
# Step table:  "label¬¶guard¬¶command"
#   guard : shell test; if it fails the step is marked SKIP and not run
#   command : the actual work (stdout+stderr -> log)
# ---------------------------------------------------------------------------
STEPS=(
  "Homebrew ¬∑ update index¬¶have brew¬¶brew update"
  "Homebrew ¬∑ upgrade formulae¬¶have brew¬¶brew upgrade"
  "Homebrew ¬∑ upgrade casks¬¶have brew¬¶brew upgrade --cask $GREEDY_FLAG"
  "Homebrew ¬∑ autoremove + cleanup¬¶have brew¬¶brew autoremove; brew cleanup -s"
  "npm ¬∑ global packages¬¶have npm¬¶npm_update_global"
  "pnpm ¬∑ global packages¬¶have pnpm¬¶pnpm_update_global"
  "yarn ¬∑ stable¬¶have yarn¬¶corepack enable; yarn set version stable"
  "bun ¬∑ self-upgrade¬¶have bun¬¶bun upgrade"
  "deno ¬∑ upgrade¬¶have deno¬¶deno upgrade 2>/dev/null||brew upgrade deno"
  "pipx ¬∑ upgrade all¬¶have pipx¬¶pipx upgrade-all"
  "uv ¬∑ self + tools¬¶have uv¬¶{ uv self update 2>/dev/null||brew upgrade uv 2>/dev/null; }; uv tool upgrade --all 2>/dev/null||true"
  "conda ¬∑ update all¬¶have conda¬¶conda update -n base -c defaults conda -y; conda update --all -y"
  "rustup ¬∑ update toolchains¬¶have rustup¬¶rustup update"
  "cargo ¬∑ update binaries¬¶have cargo¬¶{ have cargo-install-update||cargo install cargo-update; }; cargo install-update -a"
  "composer ¬∑ self + global¬¶have composer¬¶composer self-update; composer global update"
  "mise ¬∑ self + tools¬¶have mise¬¶{ mise self-update -y 2>/dev/null||brew upgrade mise 2>/dev/null; }; mise upgrade"
  "asdf ¬∑ plugins¬¶have asdf¬¶asdf update; asdf plugin update --all"
  "gcloud ¬∑ components¬¶have gcloud¬¶gcloud components update --quiet"
  "az ¬∑ CLI¬¶have az¬¶az upgrade --yes"
  "helm ¬∑ repo update¬¶have helm¬¶helm repo update"
  "krew ¬∑ plugins¬¶have kubectl && kubectl krew version >/dev/null 2>&1¬¶kubectl krew upgrade"
  "flutter ¬∑ upgrade¬¶have flutter¬¶flutter upgrade"
  "dotnet ¬∑ global tools¬¶have dotnet¬¶dotnet tool update --global --all"
  "Codex CLI¬¶have codex¬¶update_codex"
  "Supabase CLI¬¶have supabase¬¶if have brew && brew list supabase >/dev/null 2>&1; then brew upgrade supabase; elif have npm; then npm install -g supabase@latest; fi"
  "Vercel CLI¬¶have vercel¬¶if have brew && brew list vercel-cli >/dev/null 2>&1; then brew upgrade vercel-cli; elif have npm && npm list -g vercel >/dev/null 2>&1; then npm install -g vercel@latest; else echo 'vercel present but no known update source matched'; fi"
  "gh ¬∑ extensions¬¶have gh¬¶gh extension upgrade --all"
  "tldr ¬∑ cache¬¶have tldr¬¶tldr --update 2>/dev/null||tldr -u"
  "VS Code ¬∑ extensions¬¶have code¬¶code --list-extensions|sed '/^[[:space:]]*\$/d'|while IFS= read -r e; do code --install-extension \"\$e\" --force; done"
  "App Store ¬∑ upgrade¬¶have mas && [ \"$MACOS_UPDATES\" = 1 ]¬¶mas upgrade"
  "macOS ¬∑ install updates¬¶[ \"$MACOS_UPDATES\" = 1 ]¬¶sudo softwareupdate -ia --verbose"
)

TOTAL=${#STEPS[@]}
STATUS=()                       # done|skip|fail|run|pending per step
for ((i=0;i<TOTAL;i++)); do STATUS[i]="pending"; done

# ---------------------------------------------------------------------------
# Rendering
# ---------------------------------------------------------------------------
SPIN='‚Ýã‚Ýô‚Ýπ‚Ý∏‚Ýº‚Ý¥‚Ý¶‚Ýß‚Ýá‚Ýè'
FRAME=0
T0=$SECONDS
FOOTER=""

# colors (256-color palette ‚Äî renders consistently in Terminal.app, iTerm2, etc.)
C_RST=$'\033[0m'; C_DIM=$'\033[2m'; C_B=$'\033[1m'
C_CYAN=$'\033[38;5;44m'    # teal accent ‚Äî title, headings, brand
C_GRN=$'\033[38;5;48m'     # success
C_RED=$'\033[38;5;203m'    # failure
C_YEL=$'\033[38;5;221m'    # in-progress / warning
C_MAG=$'\033[38;5;176m'    # (kept for compatibility)
C_BLU=$'\033[38;5;75m'     # secondary accent
C_GRY=$'\033[38;5;240m'    # track / pending (muted)
C_FNT=$'\033[38;5;245m'    # faint body text

# Precompute a left-to-right gradient (green ‚Üí cyan ‚Üí teal ‚Üí sky) across the
# progress bar so each filled cell carries its own hue. Width is fixed, so this
# is built once rather than every frame.
BAR_W=30
RAMP=(48 48 49 50 51 45 44 43 80 80 74 75)
BAR_COL=()
for ((_i=0;_i<BAR_W;_i++)); do
  _ri=$(( _i * ${#RAMP[@]} / BAR_W ))
  BAR_COL[_i]=$'\033[38;5;'"${RAMP[_ri]}"'m'
done

SUDO_KEEPER=""; WRAP_DIR=""; PROMPT_REQ=""; PROMPT_REP=""
cleanup() { [ -n "$SUDO_KEEPER" ] && kill "$SUDO_KEEPER" 2>/dev/null; [ -n "$WRAP_DIR" ] && rm -rf "$WRAP_DIR" 2>/dev/null; tput rmcup 2>/dev/null; tput cnorm 2>/dev/null; }
trap 'cleanup; echo; echo "Interrupted. Full log: '"$LOG"'"; exit 130' INT TERM

fmt_time() { printf '%02d:%02d' $(( $1/60 )) $(( $1%60 )); }

bar() { # $1 done count, $2 total ‚Äî renders a gradient bar of width BAR_W
  local done=$1 total=$2 w=$BAR_W filled
  filled=$(( total>0 ? done*w/total : 0 ))
  local s="" i
  for ((i=0;i<filled;i++)); do s+="${BAR_COL[i]}‚ñà"; done
  s+="$C_GRY"
  for ((i=filled;i<w;i++)); do s+="‚ñë"; done
  s+="$C_RST"
  printf '%s' "$s"
}

# draw_box <title> [subtitle] ‚Äî a self-closing rounded box with a teal border.
# Width is fixed and each text line is centered by measured length, so the right
# edge always lines up. A subtitle, when given, renders dim under the title.
draw_box() {
  local title="$1" subtitle="${2:-}" W=48 t left right dash lsp rsp i
  t=${#title}; (( t > W )) && t=$W
  left=$(( (W - t) / 2 )); right=$(( W - t - left ))
  dash=""; for ((i=0;i<W;i++)); do dash+="‚îÄ"; done
  printf -v lsp '%*s' "$left"  ''
  printf -v rsp '%*s' "$right" ''
  printf '%s‚ï≠%s‚ïÆ%s\n'           "$C_CYAN" "$dash" "$C_RST"
  printf '%s‚îÇ%*s‚îÇ%s\n'          "$C_CYAN" "$W" "" "$C_RST"
  printf '%s‚îÇ%s%s%s%s%s%s‚îÇ%s\n' "$C_CYAN" "$lsp" "$C_B$C_CYAN" "$title" "$C_RST" "$rsp" "$C_CYAN" "$C_RST"
  if [ -n "$subtitle" ]; then
    local st sl sr slsp srsp
    st=${#subtitle}; (( st > W )) && st=$W
    sl=$(( (W - st) / 2 )); sr=$(( W - st - sl ))
    printf -v slsp '%*s' "$sl" ''
    printf -v srsp '%*s' "$sr" ''
    printf '%s‚îÇ%s%s%s%s%s%s‚îÇ%s\n' "$C_CYAN" "$slsp" "$C_FNT" "$subtitle" "$C_RST" "$srsp" "$C_CYAN" "$C_RST"
  else
    printf '%s‚îÇ%*s‚îÇ%s\n'          "$C_CYAN" "$W" "" "$C_RST"
  fi
  printf '%s‚ï∞%s‚ïØ%s\n'           "$C_CYAN" "$dash" "$C_RST"
}

# Build the banner once ‚Äî it never changes, so don't recompute it every frame.
BANNER="$(draw_box "‚ü≥  updatetools" "keeping your Mac fresh")"

# Prime sudo before entering the alternate screen. Some casks (e.g. Stats)
# register privileged launchctl helpers that brew removes via sudo; without a
# cached ticket the subprocess blocks silently while the TUI renders over it.
sudo_prime() {
  sudo -n true 2>/dev/null && return 0
  printf '\n%s\n\n' "$(draw_box "sudo ¬∑ password required")"
  sudo -v; local rc=$?; echo; return $rc
}

render() {
  local running_idx="${1:-} "
  local frame_char="${SPIN:FRAME%${#SPIN}:1}"
  local cols; cols=$(tput cols 2>/dev/null || echo 80)
  printf '\033[H\033[J'   # home + clear to end

  # banner (precomputed rounded box) ‚Äî centered feel with leading indent
  printf '%s\n\n' "$BANNER"

  # progress
  local fin=0 i
  for ((i=0;i<TOTAL;i++)); do
    case "${STATUS[i]}" in done|skip|fail) fin=$((fin+1));; esac
  done
  local pct=$(( TOTAL>0 ? fin*100/TOTAL : 0 ))
  printf '   %s‚ñï%s%s‚ñè   %s%d%s%s/%d%s   %s%d%%%s      %s‚è±  %s%s\n\n' \
    "$C_GRY" "$(bar "$fin" "$TOTAL")" "$C_GRY" \
    "$C_B$C_CYAN" "$fin" "$C_RST" "$C_FNT" "$TOTAL" "$C_RST" \
    "$C_YEL" "$pct" "$C_RST" \
    "$C_DIM" "$(fmt_time $((SECONDS-T0)))" "$C_RST"

  # step list ‚Äî split each label into "tool ¬∑ action"; tool stays prominent,
  # the action is dimmed, so the column scans top-to-bottom at a glance.
  for ((i=0;i<TOTAL;i++)); do
    local label="${STEPS[i]%%¬¶*}" name action
    name="$label"; action=""
    if [[ "$label" == *" ¬∑ "* ]]; then name="${label%% ¬∑ *}"; action="${label#* ¬∑ }"; fi
    local icon color
    case "${STATUS[i]}" in
      done) icon="‚úì"; color="$C_GRN" ;;
      skip) icon="¬∑"; color="$C_GRY" ;;
      fail) icon="‚úó"; color="$C_RED" ;;
      run)  icon="$frame_char"; color="$C_YEL" ;;
      *)    icon="‚óã"; color="$C_GRY" ;;
    esac
    case "${STATUS[i]}" in
      skip|pending)
        # entire row muted
        if [ -n "$action" ]; then
          printf '   %s%s  %s %s¬∑%s %s%s\n' "$color" "$icon" "$name" "$C_GRY" "$C_GRY" "$action" "$C_RST"
        else
          printf '   %s%s  %s%s\n' "$color" "$icon" "$name" "$C_RST"
        fi ;;
      *)
        local namestyle="$C_RST"
        [ "${STATUS[i]}" = run ] && namestyle="$C_B$C_YEL"
        if [ -n "$action" ]; then
          printf '   %s%s%s  %s%s%s %s¬∑%s %s%s%s\n' \
            "$color" "$icon" "$C_RST" "$namestyle" "$name" "$C_RST" \
            "$C_GRY" "$C_RST" "$C_DIM" "$action" "$C_RST"
        else
          printf '   %s%s%s  %s%s%s\n' "$color" "$icon" "$C_RST" "$namestyle" "$name" "$C_RST"
        fi ;;
    esac
  done

  # footer: a pinned summary block (when set) takes priority over the live tail
  if [ -n "${FOOTER:-}" ]; then
    printf '%s\n' "$FOOTER"
  elif [ -n "${running_idx// /}" ]; then
    local tail_line
    tail_line=$(tail -n 1 "$LOG" 2>/dev/null | tr -d '\r' | cut -c1-$((cols-6)))
    printf '\n   %s‚ï∞‚îÄ‚ñ∂%s %s%s%s\n' "$C_GRY" "$C_RST" "$C_FNT" "$tail_line" "$C_RST"
  fi
}

# ---------------------------------------------------------------------------
# Main loop
# ---------------------------------------------------------------------------
if ! [ -t 1 ]; then
  echo "Not a TTY ‚Äî falling back to plain updatetools."
  # Pass --plain so updatetools doesn't try to re-launch this dashboard (exec loop).
  exec "$(dirname "$0")/updatetools" --plain "$@"
fi

# Create an askpass helper so SSH, Git, and sudo -A prompts from background
# steps get routed through the TUI instead of blocking on /dev/tty.
# The helper writes the prompt text to a request file and waits for the TUI
# to write a reply file; the render loop below polls and handles it.
WRAP_DIR="${TMPDIR:-/tmp}/updatetools-wrap-$$"
mkdir -p "$WRAP_DIR"
PROMPT_REQ="${WRAP_DIR}/req"
PROMPT_REP="${WRAP_DIR}/rep"
# The request/reply paths are BAKED IN (unquoted heredoc expands them now)
# rather than read from the environment: brew scrubs its subprocess env down to
# an allowlist (HOMEBREW_*, SUDO_ASKPASS, PATH, ‚Ä¶), so any custom vars we export
# get stripped before the helper runs ‚Äî which left it writing to an empty path
# and spinning forever while sudo waited (the dashboard hung on launchctl).
cat > "${WRAP_DIR}/askpass" <<ASKPASS_EOF
#!/bin/bash
printf '%s' "\${1:-Password: }" > "$PROMPT_REQ"
while [ ! -f "$PROMPT_REP" ]; do sleep 0.05; done
cat "$PROMPT_REP"
rm -f "$PROMPT_REP"
ASKPASS_EOF
chmod +x "${WRAP_DIR}/askpass"
export SUDO_ASKPASS="${WRAP_DIR}/askpass"
export SSH_ASKPASS="${WRAP_DIR}/askpass"
export SSH_ASKPASS_REQUIRE="force"
export GIT_ASKPASS="${WRAP_DIR}/askpass"
export GIT_TERMINAL_PROMPT=0

sudo_prime || true
( while true; do sleep 55; sudo -n -v 2>/dev/null || break; done ) &
SUDO_KEEPER=$!

tput smcup 2>/dev/null   # alternate screen
tput civis 2>/dev/null   # hide cursor

for ((i=0;i<TOTAL;i++)); do
  entry="${STEPS[i]}"
  guard="${entry#*¬¶}"; guard="${guard%%¬¶*}"
  cmd="${entry##*¬¶}"

  if ! eval "$guard" >/dev/null 2>&1; then
    STATUS[i]="skip"; render; continue
  fi

  STATUS[i]="run"
  rm -f "$PROMPT_REQ" "$PROMPT_REP"
  # Refresh the cached sudo ticket right before a step that may need root (e.g.
  # brew removing a cask's launchctl service). -n never prompts; if the ticket
  # lapsed, brew still falls back to the askpass prompt below.
  sudo -n -v 2>/dev/null || true
  {
    # Detach the step from the TUI's controlling terminal. Without this, toggling
    # the alternate screen / reading /dev/tty for an askpass prompt delivers
    # SIGHUP (and SIGTTIN/SIGTTOU) to brew's process group ‚Äî which crashed cask
    # upgrades with "Error: SIGHUP" mid 'Removing launchctl service ...'. Ignored
    # dispositions are inherited by brew's children (sudo, launchctl).
    trap '' HUP TTIN TTOU
    echo; echo "######## ${entry%%¬¶*} ########";
    eval "$cmd";
  } >>"$LOG" 2>&1 </dev/null &
  pid=$!

  # Watchdog state: track log growth to detect a wedged step.
  last_size=$(wc -c < "$LOG" 2>/dev/null); last_size=${last_size// /}
  last_change=$SECONDS
  stalled=0

  while kill -0 "$pid" 2>/dev/null; do
    if [ -f "$PROMPT_REQ" ]; then
      prompt=$(cat "$PROMPT_REQ"); rm -f "$PROMPT_REQ"
      tput rmcup 2>/dev/null; tput cnorm 2>/dev/null
      printf '\n%s\n\n' "$(draw_box "password required")"
      printf '   %s' "$prompt"
      read_args=(-rs)
      [ "${PROMPT_TIMEOUT:-0}" -gt 0 ] 2>/dev/null && read_args+=(-t "$PROMPT_TIMEOUT")
      if IFS= read "${read_args[@]}" reply </dev/tty; then
        printf '\n\n'
        printf '%s\n' "$reply" > "$PROMPT_REP"
        tput smcup 2>/dev/null; tput civis 2>/dev/null
        last_change=$SECONDS   # don't penalise time spent waiting on the user
      else
        # No input within PROMPT_TIMEOUT ‚Äî abort the step cleanly so an
        # unattended run keeps going instead of blocking forever on the prompt.
        printf '\n\n'
        kill_tree "$pid"; sleep 1; kill -KILL "$pid" 2>/dev/null
        echo "######## no password entered within ${PROMPT_TIMEOUT}s ‚Äî step aborted ########" >> "$LOG"
        stalled=1
        tput smcup 2>/dev/null; tput civis 2>/dev/null
        break
      fi
    fi

    # Stall watchdog: no new output for STALL_TIMEOUT seconds => wedged.
    if [ "${STALL_TIMEOUT:-0}" -gt 0 ] 2>/dev/null; then
      size=$(wc -c < "$LOG" 2>/dev/null); size=${size// /}
      if [ "$size" != "$last_size" ]; then
        last_size=$size; last_change=$SECONDS
      elif [ $(( SECONDS - last_change )) -ge "$STALL_TIMEOUT" ]; then
        kill_tree "$pid"; sleep 1; kill -KILL "$pid" 2>/dev/null
        echo "######## stalled ${STALL_TIMEOUT}s with no output ‚Äî killed ########" >> "$LOG"
        stalled=1
        break
      fi
    fi

    FRAME=$((FRAME+1))
    render "$i"
    sleep 0.12
  done
  wait "$pid" 2>/dev/null; rc=$?
  if [ "$stalled" = 1 ] || [ "$rc" -ne 0 ]; then STATUS[i]="fail"; else STATUS[i]="done"; fi
  render
done

# ---------------------------------------------------------------------------
# Summary ‚Äî computed while still on the dashboard (alternate screen)
# ---------------------------------------------------------------------------
done_n=0 skip_n=0 fail_n=0
for ((i=0;i<TOTAL;i++)); do
  case "${STATUS[i]}" in
    done) done_n=$((done_n+1)) ;;
    skip) skip_n=$((skip_n+1)) ;;
    fail) fail_n=$((fail_n+1)) ;;
  esac
done
ELAPSED="$(fmt_time $((SECONDS-T0)))"

# Build the in-dashboard summary footer.
RULE=""; for ((i=0;i<50;i++)); do RULE+="‚îÄ"; done
printf -v FOOTER '\n   %s%s%s\n   %s‚ü≥ updatetools finished%s %sin %s%s\n\n   %s‚úì %d updated%s    %s¬∑ %d skipped%s    %s‚úó %d failed%s\n' \
  "$C_GRY" "$RULE" "$C_RST" \
  "$C_B$C_CYAN" "$C_RST" "$C_FNT" "$ELAPSED" "$C_RST" \
  "$C_GRN" "$done_n" "$C_RST" "$C_GRY" "$skip_n" "$C_RST" "$C_RED" "$fail_n" "$C_RST"
if [ "$fail_n" -gt 0 ]; then
  FOOTER+=$'\n'"   ${C_RED}Failed steps:${C_RST}"$'\n'
  for ((i=0;i<TOTAL;i++)); do
    [ "${STATUS[i]}" = fail ] && FOOTER+="     ${C_RED}‚úó${C_RST} ${STEPS[i]%%¬¶*}"$'\n'
  done
fi
FOOTER+=$'\n'"   ${C_FNT}Full log: ${LOG}${C_RST}"
FOOTER+=$'\n\n'"   ${C_DIM}press ${C_RST}${C_YEL}q${C_RST}${C_DIM} to quit${C_RST}"

# Render the final summary screen and wait for 'q' (Ctrl-C also exits via trap).
render
if [ -r /dev/tty ]; then
  key=""
  while IFS= read -rsn1 key 2>/dev/null </dev/tty; do
    case "$key" in q|Q) break ;; esac
  done
fi

